                }
              }
            }
          ]
        },
        {
          "ruleId": "CT006",
          "level": "error",
          "message": {
            "text": "secret 'token' received from channel (confidence: low)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "testdata/src/channels/channels.go",
                  "uriBaseId": "%SRCROOT%"
