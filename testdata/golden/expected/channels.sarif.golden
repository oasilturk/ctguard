              }
            }
          ]
        },
        {
          "ruleId": "CT006",
          "level": "error",
          "message": {
            "text": "secret 'secret' sent to channel (confidence: high)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "testdata/src/channels/channels.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 41,
                  "startColumn": 5
                }
              }
            }
          ]
        },
        {
          "ruleId": "CT006",
          "level": "error",
          "message": {
            "text": "secret 'secret' received from channel (confidence: low)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "testdata/src/channels/channels.go",
                  "uriBaseId": "%SRCROOT%"
                },
