{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "ctguard",
          "version": "<VERSION>",
          "informationUri": "https://github.com/oasilturk/ctguard",
          "rules": [
            {
              "id": "CT001",
              "name": "SecretDependentBranch",
              "shortDescription": {
                "text": "Secret-dependent branch"
              },
              "fullDescription": {
                "text": "Detects control flow that depends on secret data, which can leak information through timing differences."
              },
              "helpUri": "https://github.com/oasilturk/ctguard#ct001",
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CT002",
              "name": "NonConstantTimeComparison",
              "shortDescription": {
                "text": "Non-constant-time comparison"
              },
              "fullDescription": {
                "text": "Detects use of variable-time comparison operations (bytes.Equal, strings.Compare, ==) with secret data. Use crypto/subtle for constant-time comparisons."
              },
              "helpUri": "https://github.com/oasilturk/ctguard#ct002",
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CT003",
              "name": "SecretDependentIndexing",
              "shortDescription": {
                "text": "Secret-dependent indexing"
              },
              "fullDescription": {
                "text": "Detects array, slice, and map indexing where the index depends on secret data. This can leak information through cache-timing side-channels."
              },
              "helpUri": "https://github.com/oasilturk/ctguard#ct003",
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CT004",
              "name": "SecretDataExposure",
              "shortDescription": {
                "text": "Secret data exposure"
              },
              "fullDescription": {
                "text": "Detects when secret data is passed to logging, printing, or error formatting functions. Secrets may be exposed in logs, console output, or error messages."
              },
              "helpUri": "https://github.com/oasilturk/ctguard#ct004",
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CT005",
              "name": "VariableTimeArithmetic",
              "shortDescription": {
                "text": "Variable-time arithmetic"
              },
              "fullDescription": {
                "text": "Detects use of variable-time arithmetic operations (/, %, \u003c\u003c, \u003e\u003e) with secret data. Use crypto/subtle for constant-time arithmetic."
              },
              "helpUri": "https://github.com/oasilturk/ctguard#ct005",
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CT006",
              "name": "ChannelOperationsWithSecretData",
              "shortDescription": {
                "text": "Channel operations with secret data"
              },
              "fullDescription": {
                "text": "Detects when secret data is sent to or received from channels. Channel communication can leak timing information and create attack surfaces where goroutines can observe secret data."
              },
              "helpUri": "https://github.com/oasilturk/ctguard#ct006",
              "defaultConfiguration": {
                "level": "error"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CT006",
          "level": "error",
          "message": {
            "text": "secret 'secret' sent to channel (confidence: high)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "testdata/src/channels/channels.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 7,
                  "startColumn": 5
                }
              }
            }
          ]
        },
        {
          "ruleId": "CT006",
          "level": "error",
          "message": {
            "text": "secret 'password' sent to channel (confidence: high)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "testdata/src/channels/channels.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 12,
                  "startColumn": 5
                }
              }
            }
          ]
        },
        {
          "ruleId": "CT006",
          "level": "error",
          "message": {
            "text": "secret 'key' sent to channel (confidence: high)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "testdata/src/channels/channels.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 17,
                  "startColumn": 5
                }
              }
            }
          ]
        },
        {
          "ruleId": "CT006",
          "level": "error",
          "message": {
            "text": "secret 'key' received from channel (confidence: low)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "testdata/src/channels/channels.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 18,
