# CTGuard Configuration
# See .ctguard.yaml.example for detailed documentation

rules:
  enable:
    - all
  disable:
  #  - CT003

annotations:
  secrets:
    - package: "github.com/oasilturk/ctguard/examples/e"
      function: "*"       # all functions in the package
      params: ["key"]

  ignores:
    # Ignore a specific rule for a specific function
    - package: "github.com/oasilturk/ctguard/examples/bad"
      function: "BadFunction"
      rules: ["CT002"]
    
    # Ignore all rules for all functions in a specific package
    - package: "github.com/oasilturk/ctguard/examples/bad"
      function: "*"
      rules: all

  isolated:
    - package: "github.com/vendor/crypto"
      function: "CriticalVerify"

format: plain
fail: true
quiet: false
summary: true
min-confidence: low

exclude:
  - "testdata/**"
  - "vendor/**"
  - "**/generated/**"
  - "**/*_test.go"
  - "**/mock_*.go"
